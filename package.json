{
  "name": "pi-shrinkage",
  "version": "0.1.0",
  "description": "Hybrid RTK-style tool-result pruning plus optional small-model policy for Pi coding agent.",
  "homepage": "https://github.com/saphid/pi-shrinkage#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saphid/pi-shrinkage.git"
  },
  "bugs": {
    "url": "https://github.com/saphid/pi-shrinkage/issues"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "src",
    "dist/src",
    "test",
    "skills",
    "assets",
    "viewer",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "npm run build && node --test dist/test/*.test.js",
    "check": "npm test"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "context",
    "tool-results",
    "token-reduction",
    "rtk"
  ],
  "license": "MIT",
  "pi": {
    "extensions": [
      "./dist/src/index.js"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
